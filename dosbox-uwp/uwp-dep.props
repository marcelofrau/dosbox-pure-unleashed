<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup Label="UwpDepPaths">
    <UwpDepBase Condition="'$(UwpDepBase)'==''">$(SolutionDir)extern\uwp-dep</UwpDepBase>
  </PropertyGroup>

  <ItemDefinitionGroup Condition="'$(Platform)'=='x64'">
    <ClCompile>
      <AdditionalIncludeDirectories>$(UwpDepBase)\x64\include;$(UwpDepBase)\x64\include\SDL2;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <PreprocessorDefinitions>USING_UWP_DEP;%(PreprocessorDefinitions)</PreprocessorDefinitions>
    </ClCompile>
    <Link>
      <AdditionalLibraryDirectories>$(UwpDepBase)\x64\lib;%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
      <AdditionalDependencies>SDL2.lib;libuwp.lib;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>

  <ItemGroup Condition="'$(Platform)'=='x64'">
    <None Include="$(UwpDepBase)\x64\bin\SDL2.dll">
      <DeploymentContent>true</DeploymentContent>
    </None>
    <None Include="$(UwpDepBase)\x64\bin\libuwp.dll">
      <DeploymentContent>true</DeploymentContent>
    </None>
  </ItemGroup>
</Project>
